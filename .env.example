# OweMe API — env template. Copy to .env and fill values.
# Dev/test uses SQLite (DATABASE_URL="file:./dev.db"). Production target: PostgreSQL.
DATABASE_URL=

# JWT signing keys (auth)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=
JWT_REFRESH_TTL=

# BulkSMSNigeria (OtpSender + MessageSender). Absent BULKSMS_API_TOKEN -> stub.
BULKSMS_API_TOKEN=
BULKSMS_SENDER_ID=OweMe
# Reporting-only: kobo cost of one SMS page on the current route (default 350 = ₦3.50).
# Stamped on usage_events.costKoboEstimate; never used in a money path.
SMS_ROUTE_COST_KOBO=350

# Payment backend selector: paystack (default) | flutterwave
PAYMENT_PROVIDER=paystack

# Paystack (banks, resolve, subaccount, transaction init). Webhook sig = HMAC-SHA512(body, secret key).
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Flutterwave v3 (used when PAYMENT_PROVIDER=flutterwave)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET_HASH=

# IAP receipt verification (Apple shared secret; Google service-account JSON + package name)
APPLE_IAP_SHARED_SECRET=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=

# Google Gemini (voice parse). Absent GEMINI_API_KEY -> stub. Model defaults to gemini-3.5-flash.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Legacy alias for GEMINI_API_KEY (used only if GEMINI_API_KEY is unset)
LLM_PROVIDER_API_KEY=
