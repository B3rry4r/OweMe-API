      ],
      "endpoints": [
        {"method": "GET", "path": "/notification-preferences", "response": {"shape": "NotificationPreferences"}, "roles": ["owner"], "notes": "Backend push (owner-only surface) honors these."},
        {"method": "PUT", "path": "/notification-preferences", "body": [{"name": "payments", "type": "boolean"}, {"name": "overdue", "type": "boolean"}, {"name": "delivery", "type": "boolean"}, {"name": "weekly", "type": "boolean"}], "response": {"shape": "NotificationPreferences"}, "roles": ["owner"]}
      ]
    },
    {
