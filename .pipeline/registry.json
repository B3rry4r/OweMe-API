      "name": "Bvum",
      "module": "bvum",
      "sourceScreens": ["subscription"],
      "dependsOn": ["Debt"],
      "declarations": ["bvum-engine"],
      "endpoints": [
        {"method": "GET", "path": "/bvum", "response": {"shape": "{ value: int(kobo), ceiling: int(kobo)|null, recommendedPlan: string|null, windowDays: 30 }"}, "roles": ["owner"], "notes": "30-day observation; weights receivables 40/credit-issued 30/recovery 15/active-debtors 10/complexity 5. Ceilings starter/market ₦2M, business ₦20M, enterprise null. RECOMMENDATION only — never auto-changes plan (was computed client-side)."}
      ]
    },
    {
      "name": "Voice",
      "module": "voice",
      "sourceScreens": ["record-debt"],
      "dependsOn": ["CreditLedger"],
      "declarations": ["llm-provider", "credit-ledger"],
      "endpoints": [
        {"method": "POST", "path": "/voice/parse", "body": [{"name": "transcript", "type": "string"}, {"name": "knownCustomers", "type": "string[]", "optional": true}], "response": {"shape": "{ customerName: string|null, amount: int(kobo), description: string|null, dueDate: datetime|null }"}, "roles": ["owner", "staff"], "notes": "Transcript-only (audio upload path 501). Debits 1 AI credit on success (credit-ledger); exhaustion -> 403 PLAN_REQUIRED. Behind LlmProvider."}
      ]
    },
    {
      "name": "Insights",
      "module": "insights",
      "sourceScreens": ["dashboard"],
      "dependsOn": ["CreditLedger"],
      "declarations": ["llm-provider", "credit-ledger", "insights-dashboard"],
      "endpoints": [
        {"method": "GET", "path": "/insights/dashboard", "response": {"status": 501, "shape": "{ insights: object }"}, "roles": ["owner"], "notes": "501 scaffold (sourceScreens rendering it are stubs). Debits 5 AI credits when live. Behind LlmProvider."}
      ]
    },
    {
      "name": "Sync",
      "module": "sync",
      "sourceScreens": ["backup", "settings"],
      "dependsOn": ["Customer", "Debt", "Payment", "Reminder"],
      "declarations": ["sync"],
      "endpoints": [
        {"method": "GET", "path": "/sync", "query": [{"name": "since", "type": "string(cursor)", "optional": true}], "response": {"shape": "{ changes: {customers:[], debts:[], payments:[], reminders:[]}, tombstones: {customers:[], debts:[], payments:[], reminders:[]}, cursor: string }"}, "roles": ["owner", "staff"], "notes": "Delta pull across synced entities since cursor + tombstones. All API writes carry If-Match: version=N; stale -> 409 {error, current}. LWW per field-set. Local writes are truth until synced."},
        {"method": "GET", "path": "/sync/status", "response": {"shape": "{ lastSyncedAt: datetime|null, pendingCount: int }"}, "roles": ["owner", "staff"], "notes": "Backs the Backup screen status (pendingCount is client-side; lastSyncedAt is the cursor watermark)."}
      ]
    },
    {
      "name": "Webhooks",
      "module": "webhooks",
      "sourceScreens": [],
      "dependsOn": ["Payment", "Subscription", "Reminder"],
      "declarations": ["paystack", "iap"],
      "endpoints": [
        {"method": "POST", "path": "/webhooks/paystack", "auth": "provider-signature", "response": {"status": 200}, "roles": [], "notes": "Verify Paystack signature (PAYSTACK_WEBHOOK_SECRET). Idempotent on data.reference. Reconciles debtor pay-link charges -> records Payment/marks debt paid."},
        {"method": "POST", "path": "/webhooks/iap", "auth": "provider-signature", "response": {"status": 200}, "roles": [], "notes": "App Store Server Notifications / Play RTDN. Subscription lifecycle + out-of-band bundle credits. Verify per platform."}
      ]
    }
  ],
  "sharedInfrastructure": {
    "builtBy": "schema/pre-step agents in src/common (Phase 4)",
    "components": ["JwtAuthGuard (Bearer)", "RolesGuard + @Roles()", "EntitlementsGuard (-> 403 PLAN_REQUIRED)", "TenantMiddleware (businessId scoping from JWT)", "HttpExceptionFilter (ErrorEnvelope)", "ValidationPipe (whitelist+forbidNonWhitelisted+transform)", "If-Match/version interceptor (-> 409 VERSION_CONFLICT)", "shared DTOs (Paginated, ErrorEnvelope)", "uuidv7 + kobo money utils", "OtpSender + MessageSender interfaces (BulkSMSNigeria)", "PaystackGateway, ReceiptVerifier, LlmProvider interfaces"]
  }
