        {"method": "GET", "path": "/dashboard", "response": {"shape": "{ outstandingTotal:int(kobo), owingCustomerCount:int, recoveredThisMonth:int(kobo), dueTodayTotal:int(kobo), overdueTotal:int(kobo), overdueCount:int, activity: ActivityItem[] (cap 8), hasAnyDebts:bool, hasAnyCustomers:bool, hasUnread:bool }"}, "roles": ["owner", "staff"], "notes": "Core-recovery, never gated. Money kobo (S-1). Insight slot is the 501 insights surface (not included here)."}
      ]
    },
    {
