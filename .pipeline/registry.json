      "shape": "ActivityItem { kind: payment|debt|reminder, title: string, subtitle: string, amount: int(kobo)|null, at: datetime }",
      "endpoints": [
        {"method": "GET", "path": "/activity", "query": [{"name": "cursor", "optional": true}, {"name": "limit", "optional": true}], "response": {"shape": "Paginated<ActivityItem>"}, "roles": ["owner", "staff"], "notes": "Derived union (payments+debts+sent reminders), at desc. Excludes items whose parent debt is gone."}
      ]
    },
    {
      "name": "PayoutAccount",
      "module": "payout-account",
      "sourceScreens": ["payout-account", "settings"],
      "dependsOn": ["Business"],
      "declarations": ["paystack"],
      "fields": [
        {"name": "businessId", "type": "string", "nullable": false},
        {"name": "bankCode", "type": "string", "nullable": false},
        {"name": "accountNumber", "type": "string", "nullable": false, "note": "10-digit NUBAN"},
        {"name": "accountName", "type": "string", "nullable": false, "note": "resolved via Paystack"}
      ],
      "endpoints": [
        {"method": "GET", "path": "/banks", "response": {"shape": "Bank[] {code, name}"}, "roles": ["owner"], "notes": "Proxies Paystack bank list."},
        {"method": "POST", "path": "/payout-account/resolve", "body": [{"name": "bankCode", "type": "string"}, {"name": "accountNumber", "type": "string(10-digit)"}], "response": {"shape": "{ accountName: string }"}, "roles": ["owner"], "notes": "Paystack name lookup; invalid account -> error envelope."},
        {"method": "GET", "path": "/payout-account", "response": {"shape": "PayoutAccount|null"}, "roles": ["owner"]},
        {"method": "PUT", "path": "/payout-account", "body": [{"name": "bankCode", "type": "string"}, {"name": "accountNumber", "type": "string"}, {"name": "accountName", "type": "string"}], "response": {"shape": "PayoutAccount"}, "roles": ["owner"], "notes": "Creates/updates the business's Paystack subaccount from these 3 fields; nothing else stored. Writes Business.paystackSubaccount."}
      ]
    },
    {
      "name": "Plan",
      "module": "plans",
      "sourceScreens": ["compare-plans", "subscription", "usage", "upgrade", "debt-detail", "staff"],
      "dependsOn": [],
      "reference": true,
      "shape": "Plan { id: starter|market|business|enterprise, name, pricePerMonth: int(kobo, 0=free), tagline, features: string[], productId: string|null, talkToSales: bool, recommended: bool, limits: { sendsPerMonth:int(-1 fair-use), aiCreditsPerMonth:int(-1 fair-use), staffSeats:int(-1 unlimited), bvumCeiling:int(kobo)|null } }",
      "catalog": "starter free / market ₦2,500 / business ₦6,000 / enterprise from ₦18,000 (talkToSales). Prices -> kobo per S-1 (0=free; enterprise off-store). Matches billing.dart kPlans (f476925). Allowances per conventions Metering.",
      "endpoints": [
        {"method": "GET", "path": "/plans", "response": {"shape": "Plan[]"}, "roles": ["owner", "staff"], "notes": "Server-authoritative plan/pricing catalog (replaces inline kPlans/_tiers)."}
      ]
    },
    {
      "name": "Subscription",
      "module": "billing",
      "sourceScreens": ["subscription", "upgrade", "billing-history", "usage", "settings"],
      "dependsOn": ["Business", "Plan", "CreditLedger", "SendAllowanceLedger"],
      "declarations": ["iap"],
      "fields": [
        {"name": "businessId", "type": "string", "nullable": false},
        {"name": "planId", "type": "string(canonical)", "nullable": false},
        {"name": "entitlementState", "type": "string(enum: none|pending|active|gracePeriod|expired)", "nullable": false},
        {"name": "activePlanId", "type": "string(canonical)", "nullable": false},
        {"name": "renewalAt", "type": "datetime", "nullable": true, "note": "server-owned (was hardcoded mock)"}
      ],
      "billingTransaction": "BillingTransaction { id, businessId, kind: subscription|messages-bundle|ai-bundle, productId, label, amount: int(kobo), createdAt }",
      "endpoints": [
        {"method": "GET", "path": "/subscription", "response": {"shape": "{ planId, entitlementState, activePlanId, renewalAt }"}, "roles": ["owner"], "notes": "Server is SOLE entitlement authority (client display-only)."},
        {"method": "POST", "path": "/billing/verify-receipt", "body": [{"name": "platform", "type": "ios|android"}, {"name": "productId", "type": "string"}, {"name": "receipt", "type": "string"}], "response": {"shape": "{ entitlement?: Subscription, ledger?: {sendAllowance|aiCredits} }"}, "roles": ["owner"], "notes": "Verifies receipt with Apple/Google (iap declaration), then routes by productId: plan product -> sets Business.plan + entitlement; oweme_sends_* -> credits SendAllowanceLedger; oweme_ai_credits_* -> credits CreditLedger. Idempotent on store transaction id. Also credited out-of-band via POST /webhooks/iap."},
        {"method": "GET", "path": "/billing/history", "query": [{"name": "cursor", "optional": true}, {"name": "limit", "optional": true}], "response": {"shape": "Paginated<BillingTransaction>"}, "roles": ["owner"], "notes": "IAP purchase history (renewals + bundles). Money kobo."}
      ]
    },
    {
      "name": "Usage",
      "module": "ledgers",
      "sourceScreens": ["usage", "subscription", "record-debt"],
      "dependsOn": ["Business", "Plan"],
      "declarations": ["credit-ledger", "allowance-ledger"],
      "tables": ["CreditLedger (businessId, balance, monthlyGrant, periodStart)", "SendAllowanceLedger (businessId, remaining, monthlyGrant, periodStart)"],
      "note": "Owns both ledgers + their debit/credit services (imported by reminders=debitSend, voice/insights/risk=debitCredits, billing=creditBundle). Weighted AI debit: voice 1, insight 5, risk 5, debit-on-success only. Monthly grant per plan.",
      "endpoints": [
        {"method": "GET", "path": "/usage", "response": {"shape": "{ sendAllowance: {used, remaining, monthlyGrant, periodStart}, aiCredits: {used, balance, monthlyGrant, periodStart} }"}, "roles": ["owner"], "notes": "Both meters (mocked prefs as-built -> real ledgers). Caps from Plan limits."}
      ]
    },
